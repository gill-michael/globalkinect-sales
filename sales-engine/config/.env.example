# Copy this file to `.env` in the same directory and fill in your keys.
# NEVER commit .env to git.

# Get from https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-...

# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Output folder root. Each lead becomes a subfolder under this.
# Windows example: C:\dev\globalkinect\sales\leads
# Mac/Linux example: /Users/you/dev/globalkinect/sales/leads
LEADS_ROOT=C:\dev\globalkinect\sales\leads

# Model overrides (optional — defaults are fine)
# PERPLEXITY_MODEL=sonar-deep-research
# CLAUDE_MODEL=claude-opus-4-7
